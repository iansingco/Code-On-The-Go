# Copy to .env and fill in your values. Never commit .env to git.

# ── KASM ─────────────────────────────────────────────────────────────────────
# Your host machine's IP (LAN or Tailscale). Used so the status page at :8080
# can link directly to the KASM portal.
HOST_IP=192.168.1.42

# ── CI/CD Webhook ─────────────────────────────────────────────────────────────
# Must match the secret set in GitHub → Settings → Webhooks.
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=changeme

# Set to true to automatically rebuild the claude-code workspace image on push.
# The rebuilt image must then be re-registered in KASM admin panel manually.
REBUILD_WORKSPACES=false
