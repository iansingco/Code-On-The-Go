# Copy to .env and fill in your values. Never commit .env to git.

# ── Stream password ───────────────────────────────────────────────────────────
# Password for the KasmVNC login screen on every stream.
# Username is always: kasm_user
KASM_PASSWORD=password

# ── Claude Code ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CI/CD Webhook ─────────────────────────────────────────────────────────────
# Must match the secret set in GitHub → Settings → Webhooks
WEBHOOK_SECRET=changeme

# ── Docker Compose project name ───────────────────────────────────────────────
# Used to build container names (e.g. streaming-desktop-1)
COMPOSE_PROJECT=streaming
