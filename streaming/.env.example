# Copy to .env and fill in your values. Never commit .env to git.

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Absolute path to this streaming/ directory ON THE HOST MACHINE.
# The launcher runs inside Docker but spawns sibling containers via the
# Docker socket — it needs the HOST path to set up volume mounts correctly.
#
# Windows example:
#   HOST_REPO_PATH=C:\Users\tweed\Documents\GitHub\Code-On-The-Go\streaming
# Linux/Mac example:
#   HOST_REPO_PATH=/home/you/Code-On-The-Go/streaming
HOST_REPO_PATH=

# ── STREAMS ──────────────────────────────────────────────────────────────────

# Password for every KasmVNC stream login screen.
# Username is always: kasm_user
KASM_PASSWORD=password

# ── CLAUDE CODE ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CI/CD WEBHOOK ─────────────────────────────────────────────────────────────
# Must match the secret in GitHub → Settings → Webhooks.
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=changeme
