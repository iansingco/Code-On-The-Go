# Copy this to .env and fill in your values.
# .env is never committed to git.

# ── Neko stream passwords ─────────────────────────────────────────────────────
# Password for viewers connecting to any stream
NEKO_PASSWORD=stream

# Admin password (gives extra controls in the neko UI)
NEKO_PASSWORD_ADMIN=admin

# Screen resolution and framerate for all streams
# Common options: 1280x720@30, 1920x1080@30, 1024x768@60
NEKO_SCREEN=1280x720@30

# ── Claude Code ───────────────────────────────────────────────────────────────
# Required for the claude-code streaming container
ANTHROPIC_API_KEY=sk-ant-...

# ── CI/CD Webhook ─────────────────────────────────────────────────────────────
# Must match the secret set in GitHub → Settings → Webhooks
# Generate a strong random secret: openssl rand -hex 32
WEBHOOK_SECRET=changeme

# ── Docker Compose project name ───────────────────────────────────────────────
# Used to build container names (e.g. streaming-claude-code-1)
# Change this if you run multiple instances on the same host
COMPOSE_PROJECT=streaming

# ── Optional: enable Godot profile ───────────────────────────────────────────
# Uncomment to start the godot-game container automatically
# COMPOSE_PROFILES=godot
